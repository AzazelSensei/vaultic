# vaultic — Infisical self-host .env (SUBSET)
#
# This is the vaultic-RELEVANT SUBSET only, with placeholders + cautions.
# The FULL variable list comes from upstream:
#   curl -fsSL https://raw.githubusercontent.com/Infisical/infisical/main/.env.example -o .env
# Copy upstream's .env, then make sure these keys are set correctly.

# CANNOT be changed after first boot. Losing it = ALL secret data unrecoverable.
# Generate: openssl rand -hex 16   — BACK IT UP together with the Postgres (pg_data) volume.
ENCRYPTION_KEY=replace-with-openssl-rand-hex-16

# Backend auth/session signing secret. Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Public URL of the instance (used in emails, redirects, OAuth).
# Local dev: http://localhost:80   Production: https://vault.example.com
SITE_URL=http://localhost:80

# Redis connection. Default points at the compose 'redis' service.
REDIS_URL=redis://redis:6379

# Postgres connection. Default points at the compose 'db' service; the vars below
# are also defined in upstream's .env.
DB_CONNECTION_URI=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# --- SMTP (OPTIONAL) ---------------------------------------------------------
# Required ONLY for user invites / email verification (team scenario).
# A single-user deploy can leave all of these blank.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=
